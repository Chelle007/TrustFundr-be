# CORS — Next.js dev server (TrustFundr frontend)
ALLOWED_ORIGIN=http://localhost:3000

# Database (local example; use your hosted URL for Supabase, etc.)
DB_URL=jdbc:postgresql://localhost:5432/trustfundr
DB_USERNAME=postgres
DB_PASSWORD=your_password
# create-drop | update | validate
DB_UPDATE=update

# Swagger / OpenAPI
API_DOCS=/v1/api-docs
API_DOCS_HTML=/swagger-ui.html
DEV_URL=http://localhost:8080
STG_URL=http://localhost:8080
PROD_URL=http://localhost:8080

# Optional SQL logging
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# JWT (required; use a random string of at least 32 bytes)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION_SECONDS=86400
